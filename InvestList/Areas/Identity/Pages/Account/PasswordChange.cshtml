@page
@model InvestList.Areas.Identity.Pages.Account.PasswordChangeModel

@{
    ViewData["Title"] = "Змінити пароль";
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

<div id="passwordForm" class="form-container">
    <h4>Змінити пароль</h4>
    <form method="post">
        <div class="form-group mb-1">
            <label asp-for="CurrentPassword" class="control-label"></label>
            <input asp-for="CurrentPassword" class="form-control mb-1" />
            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
        </div>
        <div class="form-group mb-1">
            <label asp-for="NewPassword" class="control-label"></label>
            <input asp-for="NewPassword" class="form-control mb-1" />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>
        <div class="form-group mb-1">
            <label asp-for="ConfirmPassword" class="control-label"></label>
            <input asp-for="ConfirmPassword" class="form-control mb-1" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary mb-3">Зберегти</button>
        <button type="button" class="btn btn-secondary mb-3">Скасувати</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
