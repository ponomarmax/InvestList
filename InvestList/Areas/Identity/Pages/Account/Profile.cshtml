@page
@model ProfileModel
@{
    ViewData["Title"] = "Профіль";
}

<!-- ========================================================= -->
<!--  PROFILE ACTIONS – mobile‑friendly card centred on page   -->
<!-- ========================================================= -->
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">

            <div class="card shadow-sm rounded-4">
                <div class="card-body p-4 text-center">

                    <h1 class="h4 fw-semibold mb-4">Керування профілем</h1>

                    <!-- action buttons stack on mobile, sit side‑by‑side on lg -->
                    <div class="d-grid gap-2 d-lg-flex justify-content-lg-between">

                        <a asp-area="Identity" asp-page="/Account/LoginChange"
                           class="btn btn-outline-primary rounded-pill px-4 flex-fill">
                            Змінити логін
                        </a>

                        <a asp-area="Identity" asp-page="/Account/PasswordChange"
                           class="btn btn-outline-primary rounded-pill px-4 flex-fill">
                            Змінити пароль
                        </a>

                        <a asp-area="Identity" asp-page="/Account/DeleteAccount"
                           class="btn btn-danger rounded-pill px-4 flex-fill">
                            Видалити акаунт
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}