@* @page *@
@model RegisterModel
@{
    ViewData["Title"] = "Зареєструватися";
}

<!-- PAGE WRAPPER -->
<div class="container py-5">

    <!-- ---------- CARD ---------- -->
    <div class="card shadow-sm mx-auto" style="max-width: 420px;">   <!-- 420 px ≈ comfortable mobile / desktop width -->
        <div class="card-body p-4">

            <!-- Heading -->
            <h1 class="h4 fw-semibold text-center mb-4">Створити новий обліковий запис</h1>

            <!-- Register form -->
            <form id="registerForm"
                  asp-route-returnUrl="@Model.ReturnUrl"
                  method="post"
                  novalidate>

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <!-- Email -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email"
                           class="form-control"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="name@example.com" />
                    <label asp-for="Input.Email">Електронна пошта</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <!-- Username -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Username"
                           class="form-control"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="Username" />
                    <label asp-for="Input.Username">Ім’я користувача на сайті</label>
                    <span asp-validation-for="Input.Username" class="text-danger small"></span>
                </div>

                <!-- Password -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password"
                           class="form-control"
                           type="password"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Пароль" />
                    <label asp-for="Input.Password">Пароль</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <!-- Confirm -->
                <div class="form-floating mb-4">
                    <input asp-for="Input.ConfirmPassword"
                           class="form-control"
                           type="password"
                           autocomplete="new-password"
                           aria-required="true"
                           placeholder="Підтвердити пароль" />
                    <label asp-for="Input.ConfirmPassword">Підтвердіть пароль</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <!-- Submit -->
                <button id="registerSubmit"
                        type="submit"
                        class="btn btn-primary w-100">
                    Зареєструватися
                </button>

                <!-- Anti‑bot hidden inputs -->
                <input type="hidden" id="timeSpent"           asp-for="Input.TimeSpent" />
                <input type="hidden" id="mouseMoved"          asp-for="Input.MouseMoved" />
                <input type="hidden" id="navigatorWebdriver"  asp-for="Input.NavigatorWebdriver" />
                <input type="hidden" id="hasChrome"           asp-for="Input.HasChrome" />
                <input type="hidden" id="screenHeight"        asp-for="Input.ScreenHeight" />
                <input type="hidden" id="screenWidth"         asp-for="Input.ScreenWidth" />
            </form>
        </div>
    </div>

    <!-- External log‑in providers -->
    <div class="mt-4 d-flex justify-content-center">
        @await Html.PartialAsync("_ExternalLogin", (Model.ExternalLogins, Model.ReturnUrl))
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        /*  Keeps the original bot‑detection logic intact  */
        let startTime = Date.now();
        let mouseMoved = false;

        document.addEventListener("mousemove", () => { mouseMoved = true; });

        function collectData() {
            const timeSpent = Date.now() - startTime;

            document.getElementById("timeSpent").value          = timeSpent;
            document.getElementById("mouseMoved").value         = mouseMoved;
            document.getElementById("navigatorWebdriver").value = navigator.webdriver;
            document.getElementById("hasChrome").value          = !!window.chrome;
            document.getElementById("screenHeight").value       = screen.height;
            document.getElementById("screenWidth").value        = screen.width;
        }

        document.getElementById("registerForm")
                .addEventListener("submit", collectData);
    </script>
}