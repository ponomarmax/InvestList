@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Відправити емейл повторно";
}

<h1>@ViewData["Title"]</h1>
<div class="d-flex justify-content-center">
    <h2 class="text-center">Ви ще не підтвердили емейл. Введіть ваш емейл для відправлення нового листа</h2>
</div>
<hr/>
<div class="d-flex justify-content-center">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-floating">
                <input asp-for="Input.Email" class="form-control" aria-required="true"/>
                <label asp-for="Input.Email" class="form-label"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">Відправити повторно</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}