@page "/blacklist"
@model InvestList.Areas.Main.Pages.Blacklist.List

<section class="py-5">
    <div class="container">

        <h1 class="h3 fw-bold mb-4">Чорний список</h1>

        @if (Model.Entities?.Any() == true)
        {
            <div class="masonry">
                @foreach (var ad in Model.Entities)
                {
                    <div class="masonry-item mb-4">
                        @* mb-4 keeps rows apart on mobile *@
                        @await Html.PartialAsync("List/_PostCard", ("Blacklist", ad))
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">Немає новин про шахраїв</p>
        }
    </div>
</section>

@if (Model.Entities?.Any() == true)
{
    <div class="d-flex justify-content-center mt-5">
        @await Html.PartialAsync(
            "_Pagination",
            ("blacklist", Model.PaginationInfo, Model.TagIds))
    </div>
}