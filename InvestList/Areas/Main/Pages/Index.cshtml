                                <div class="feature-card-text">
                                    <p class="text-muted mb-0">Інвестиційні проєкти з України, новини, чорний список шахраїв, відгуки та коментарі. Ретельно перевіряйте проекти та власників перед інвестуванням!</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="feature-card-actions">
                            <a href="/Invest/List" class="btn btn-dark rounded-square px-3 py-2">
                                <i class="bi bi-grid-3x3-gap me-1"></i>Проекти
                            </a>
                            <a href="/News/List" class="btn btn-outline-dark rounded-square px-3 py-2">
                                <i class="bi bi-newspaper me-1"></i>Новини
                            </a>
                            <a href="#" class="btn btn-outline-dark rounded-square px-3 py-2">
                                <i class="bi bi-chat-dots me-1"></i>Відгук
                            </a>
                            <a href="/Blacklist/List" class="btn btn-outline-dark rounded-square px-3 py-2">
                                <i class="bi bi-exclamation-triangle me-1"></i>Blacklist
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PROJECTS SECTION -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="h3 fw-bold mb-2">Проекти</h2>
                <p class="text-muted mb-0">Знайдіть проект для інвестування серед доступних пропозицій</p>
            </div>
        </div>

        <!-- Tags Filter - Interactive -->
        <div class="tags-filter">
            <div class="scroll-gradient-left"></div>
            <div class="scroll-gradient-right"></div>
            <div class="tags-filter-wrapper" id="tagFilterContainer">
                <button class="tag-filter-btn active rounded-square" data-tag-id="all">Всі проекти</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="agro">Агро</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="real-estate">Нерухомість</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="tech">Технології</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="energy">Енергетика</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="it">IT</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="finance">Фінанси</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="logistics">Логістика</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="retail">Рітейл</button>
                <button class="tag-filter-btn rounded-square" data-tag-id="manufacturing">Виробництво</button>
            </div>
        </div>

        <!-- Project Cards -->
        <div class="row g-4">
            @for (var i = 1; i <= 3; i++)
            {
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="position-relative">
                            <div class="bg-light" style="height: 200px;"></div>
                            <div class="position-absolute top-0 start-0 p-3">
                                <div class="d-flex gap-2">
                                    <span class="badge bg-dark rounded-square">Агро</span>
                                    <span class="badge bg-dark rounded-square">Еко</span>
                                    <span class="badge bg-dark rounded-square">Стартап</span>
                                    <span class="badge bg-dark rounded-square">Експорт</span>
                                </div>
                            </div>
                            <div class="position-absolute bottom-0 end-0 p-2">
                                <span class="badge bg-dark rounded-square">@(i == 1 ? "104" : i == 2 ? "36" : "71")</span>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-3">Інвестиційний проект @i</h5>
                            <p class="card-text text-muted mb-4">Короткий опис проекту та його переваги для інвесторів</p>
                            <div class="row g-3 mt-auto">
                                <div class="col-6">
                                    <small class="text-muted d-block">Мін. інвестиція</small>
                                    <strong>$@(i == 1 ? "100000" : i == 2 ? "100000" : "80000")</strong>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted d-block">ROI</small>
                                    <strong>@(i == 1 ? "22" : i == 2 ? "21" : "19")% / рік</strong>
                                </div>
                                <div class="col-12">
                                    <small class="text-muted d-block">Термін</small>
                                    <strong>@(i == 1 ? "23" : i == 2 ? "14" : "16") місяців</strong>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 text-end py-3">
                            <a href="#" class="btn btn-link text-dark text-decoration-none rounded-square">Детальніше <i class="bi bi-arrow-right"></i></a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Ad Section -->
<section class="py-5">
    <div class="container">
        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7409000941565147"
                crossorigin="anonymous"></script>
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-format="autorelaxed"
             data-ad-client="ca-pub-7409000941565147"
             data-ad-slot="8253400351"></ins>
        <script>
            (adsbygoogle = window.adsbygoogle || []).push({});
        </script>
    </div>
</section>

<!-- NEWS SECTION (Simplified Cards - No Tags) -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4 fw-bold mb-0">Останні новини</h2>
            <a href="/News/List" class="btn btn-outline-dark btn-sm rounded-square px-4">Всі новини</a>
        </div>
        
        <div class="row g-4">
            @if (Model.NewsPosts != null && Model.NewsPosts.Any())
            {
                foreach (var news in Model.NewsPosts.Take(3))
                {
                    <div class="col-lg-4">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="position-relative">
                                @if (news.Image != null)
                                {
                                    <img src="@news.Image.FilePath" class="card-img-top" alt="@news.Image.AltText" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light" style="height: 200px;"></div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title mt-auto">@news.Title</h5> 
                            </div>
                            <div class="card-footer bg-transparent border-0 text-end py-3">
                                <a href="/News/Details/@news.Id" class="btn btn-link text-dark text-decoration-none rounded-square">Детальніше <i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12"><p class="text-muted">Новин немає.</p></div>
            }
        </div>
    </div>
</section>

<!-- BLACKLIST SECTION (Simplified Cards) -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4 fw-bold mb-0">Blacklist</h2>
            <a href="/Blacklist/List" class="btn btn-outline-dark btn-sm rounded-square px-4">Весь blacklist</a>
        </div>
        
        <div class="row g-4">
            @if (Model.BlacklistPosts != null && Model.BlacklistPosts.Any())
            {
                foreach (var blacklist in Model.BlacklistPosts.Take(3))
                {
                    <div class="col-lg-4">
                        <div class="card h-100 border-0 shadow-sm">
                             <div class="position-relative">
                                @if (blacklist.Image != null)
                                {
                                    <img src="@blacklist.Image.FilePath" class="card-img-top" alt="@blacklist.Image.AltText" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light" style="height: 200px;"></div>
                                }
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title mt-auto">@blacklist.Title</h5>
                            </div>
                           <div class="card-footer bg-transparent border-0 text-end py-3">
                                <a href="/Blacklist/Details/@blacklist.Id" class="btn btn-link text-dark text-decoration-none rounded-square">Детальніше <i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                }
            }
             else
            {
                <div class="col-12"><p class="text-muted">Записів у блеклісті немає.</p></div>
            }
        </div>
    </div>
</section>

