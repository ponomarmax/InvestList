@page "{culture:regex(^[a-z]{{2}}$)}"
@using System.Globalization
@using System.Text.RegularExpressions
@using InvestList.Services
@using Core.Interfaces
@using InvestList
@using Radar.UI
@using Radar.UI.Pages
@model InvestList.Areas.Main.Pages.Index
@inject IInvestService InvestService
@inject ITagRepository tagService

<!-- HERO SECTION -->
<section class="py-4">
    <div class="container">
        <div class="row g-4">
            <!-- Left Card: For Business -->
            <div class="col-lg-6">
                <div class="bg-light rounded-4 feature-card">
                    <div class="feature-card-body">
                        <div>
                            <div class="feature-card-title">
                                <div>
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bi bi-briefcase me-2"></i>
                                        <span class="text-muted">Для бізнесу</span>
                                    </div>
                                    <h2 class="h3 fw-bold feature-card-heading">Бізнес шукає інвестиції</h2>
                                </div>
                            </div>

                            <div class="feature-card-content">
                                <div class="feature-card-text">
                                    <p class="text-muted mb-0">Зареєструйте свій проект для пошуку інвесторів та отримайте доступ до спільноти інвесторів. <strong>Реєстрація безкоштовна!</strong></p>
                                </div>
                            </div>
                        </div>

                        <div class="feature-card-actions">
                            <a href="/Invest/Add" class="btn btn-dark rounded-square px-3 py-2">
                                <i class="bi bi-plus-circle me-1"></i>Додати проект
                            </a>
                            <a href="/Invest/List" class="btn btn-outline-dark rounded-square px-3 py-2">
                                <i class="bi bi-grid-3x3-gap me-1"></i>Проекти
                            </a>
                            <a href="/News/List" class="btn btn-outline-dark rounded-square px-3 py-2">
                                <i class="bi bi-newspaper me-1"></i>Новини
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Card: For Investors -->
            <div class="col-lg-6">
                <div class="bg-light rounded-4 feature-card">
                    <div class="feature-card-body">
                        <div>
                            <div class="feature-card-title">
                                <div>
                                    <div class="d-flex align-items-center mb-1">
                                        <i class="bi bi-graph-up-arrow me-2"></i>
                                        <span class="text-muted">Для інвесторів</span>
                                    </div>
                                    <h2 class="h3 fw-bold feature-card-heading">Інвестор шукає прибуток</h2>
                                </div>
                                <div class="feature-card-counter">
                                    <span class="h4 fw-bold mb-0 me-2">138</span>
                                    <span class="text-muted small">проектів</span>
                                </div>
                            </div>

                            <div class="feature-card-content">
                                <div class="feature-card-text">
                                    <p class="text-muted mb-0">Інвестиційні проєкти з України, новини, чорний список шахраїв, відгуки та коментарі. Ретельно перевіряйте проекти та власників перед інвестуванням!</p>
                                </div>
                            </div>
                        </div>

                        <div class="feature-card-actions">
                            <a href="/Invest/List" class="btn btn-dark rounded-square px-3 py-2">
                                <i class="bi bi-grid-3x3-gap me-1"></i>Проекти
                            </a>
                            <a href="/News/List" class="btn btn-outline-dark rounded-square px-3 py-2">
                                <i class="bi bi-newspaper me-1"></i>Новини
                            </a>
                            <a href="#" class="btn btn-outline-dark rounded-square px-3 py-2">
                                <i class="bi bi-chat-dots me-1"></i>Відгук
                            </a>
                            <a href="/Blacklist/List" class="btn btn-outline-dark rounded-square px-3 py-2">
                                <i class="bi bi-exclamation-triangle me-1"></i>Blacklist
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PROJECTS SECTION -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="h3 fw-bold mb-2">Проекти</h2>
                <p class="text-muted mb-0">Знайдіть проект для інвестування серед доступних пропозицій</p>
            </div>
        </div>

        <!-- Tags Filter - Interactive -->
        <div class="tags-filter">
            <div class="scroll-gradient-left"></div>
            <div class="scroll-gradient-right"></div>
            <div class="tags-filter-wrapper" id="tagFilterContainer">
                <button class="tag-filter-btn active rounded-square" data-tag-id="all">Всі проекти</button>

                @{
                    var header = await tagService.GetCustomHeader(CultureInfo.CurrentUICulture.TwoLetterISOLanguageName);
                    if (header?.Count() > 0)
                    {
                        @foreach (var tag in header)
                        {
                            <a class="tag-filter-btn rounded-square" data-tag-id="agro" asp-area="Main" asp-page="/Index"
                               asp-all-route-data="@(PaginationHelper.GetPaginationData(tagIds: new[] { tag.TagId }))">
                                @tag.Tag.Translations.FirstOrDefault().Name
                            </a>
                        }
                    }
                }
            </div>
        </div>

        <!-- Project Cards -->
        <div class="row g-4">
            @foreach (var investPost in Model.InvestPosts)
            {
                <div class="col-lg-4">
                    @await Html.PartialAsync("_InvestCard", investPost)
                </div>
            }
        </div>
    </div>
</section>

<!-- Ad Section -->
<section class="py-5">
    <div class="container">
        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7409000941565147"
                crossorigin="anonymous"></script>
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-format="autorelaxed"
             data-ad-client="ca-pub-7409000941565147"
             data-ad-slot="8253400351">
        </ins>
        <script>
            (adsbygoogle = window.adsbygoogle || []).push({});
        </script>
    </div>
</section>

<!-- NEWS SECTION (Simplified Cards - No Tags) -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4 fw-bold mb-0">Останні новини</h2>
            <a href="/News/List" class="btn btn-outline-dark btn-sm rounded-square px-4">Всі новини</a>
        </div>

        <div class="row g-4">
            @if (Model.NewsPosts != null && Model.NewsPosts.Any())
            {
                foreach (var news in Model.NewsPosts.Take(3))
                {
                    <div class="col-lg-4">
                        @await Html.PartialAsync("List/_PostCard", ("News", news))
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <p class="text-muted">Новин немає.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- BLACKLIST SECTION (Simplified Cards) -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4 fw-bold mb-0">Blacklist</h2>
            <a href="/Blacklist/List" class="btn btn-outline-dark btn-sm rounded-square px-4">Весь blacklist</a>
        </div>

        <div class="row g-4">
            @if (Model.BlacklistPosts != null && Model.BlacklistPosts.Any())
            {
                foreach (var blacklist in Model.BlacklistPosts.Take(3))
                {
                    <div class="col-lg-4">
                        @await Html.PartialAsync("List/_PostCard", ("Blacklist", blacklist))
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <p class="text-muted">Записів у блеклісті немає.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- FOOTER -->
