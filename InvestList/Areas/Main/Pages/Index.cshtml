@page
@using InvestList
@using InvestList.Services
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model InvestList.Areas.Main.Pages.Index
@inject IInvestService InvestService

@if (!Model.HttpContext.Request.QueryString.HasValue)
{
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="mb-3">
                    <h1>Бізнес шукає інвестиції</h1>
                    <p>Зареєструйте свій проект для пошуку інвесторів</p>
                    <h1>Інвестор шукає прибуток</h1>
                    <p>Знайдіть інвестиційний проект, який забезпечить пасивний прибуток</p>
                </div>
            </div>
            <div class="col-lg-6">
                <div>
                    <h1>Проектів для інвестування</h1>
                    <div class="number">@await InvestService.Count()</div>
                </div>
            </div>
        </div>
    </div><br><br>
}
<div class="container">
    <div class="d-flex justify-content-center">
        <h2>Останні оголошення від бізнесу</h2>
    </div><br>
    @if (Model.InvestPosts != null && Model.InvestPosts.Any())
    {
        <div class="row">
            @foreach (var ad in Model.InvestPosts)
            {
                <div class="col-12 col-lg-6 mb-4">
                    @await Html.PartialAsync("_InvestCard", ad)
                </div>
            }
        </div>
        <div class="d-flex justify-content-center">
            <a class="news"
               asp-area="Main"
               asp-page="/Invest/List"
               asp-all-route-data="@(InvestmentHelper.GetPaginationData(tagIds: Model.TagIds))">
                Більше оголошень
            </a>
        </div>
    }
    else
    {
        <p>Немає оголошень за даним критерієм</p>
    }
    <hr/>
    <hr/>
    <div class="d-flex justify-content-center">
        <h2>Останні новини</h2>
    </div>
    @if (Model.NewsPosts != null && Model.NewsPosts.Any())
    {
        <div class="row">
            @foreach (var ad in Model.NewsPosts)
            {
                <div class="col-12 col-lg-6 mb-4">
                    @await Html.PartialAsync("_PostCard", ad)
                </div>
            }
        </div>
        <div class="d-flex justify-content-center">
            <a class="news"
               asp-area="Main"
               asp-page="/News/List"
               asp-all-route-data="@(InvestmentHelper.GetPaginationData(tagIds: Model.TagIds))">
                Більше новини
            </a>
        </div>
    }
    else
    {
        <p>Немає новин за даним критерієм</p>
    }
</div>