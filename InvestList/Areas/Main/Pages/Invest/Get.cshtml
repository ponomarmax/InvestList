@page "/invest/{id}"
@using InvestList
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using System.Text.RegularExpressions
@using Radar.UI
@using Radar.UI.Pages.Shared.Get
@model InvestList.Areas.Main.Pages.Invest.Get

<div class="container py-4">

    <!-- Controls -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
                <i class="bi bi-arrow-left me-1"></i> Назад
            </button>
            @if (Model.CanUserEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Post.Post.Id" class="btn btn-primary btn-sm">
                    Редагувати
                </a>
            }
        </div>
        <a asp-page="./List" class="btn btn-secondary btn-sm">Усі проекти</a>
    </div>

    <div class="row gx-lg-3 gy-5">
        <!-- ======== MAIN COLUMN ======== -->
        <div class="col-lg-8">

            <div class="border border-success rounded-3 p-3" style="max-width:75ch;">

                <!-- Title -->
                <h1 class="h3 fw-semibold mb-2">@Model.Post.Post.Title</h1>

                <!-- Tags right under title -->
                @await Html.PartialAsync("Get/PostTags", Model.Post.Post.Tags)

                <!-- Metrics grid (2×2 on md+, 1×4 on mobile) -->
                <div class="row row-cols-1 row-cols-md-2 g-0 border rounded mb-3">

                    @if (Model.Post.TotalInvestment > 0)
                    {
                        <div class="col p-3">
                            <span class="text-muted small">Загальний обсяг інвестицій</span><br/>
                            <span class="fw-medium">$@Model.Post.TotalInvestment</span>
                        </div>
                    }

                    <div class="col p-3 border-start">
                        <span class="text-muted small">Період інвестування</span><br/>
                        <span class="fw-medium">
                            @InvestmentHelper.FormatInvestmentDuration(Model.Post.InvestDurationYears, Model.Post.InvestDurationMonths)
                        </span>
                    </div>

                    <div class="col p-3 border-top border-md-top-0 border-start">
                        <span class="text-muted small">Річна дохідність</span><br/>
                        <span class="fw-medium">@Model.Post.AnnualInvestmentReturn.ToString("0.")%</span>
                    </div>

                    <div class="col p-3 border-top border-md-top-0 border-start">
                        <span class="text-muted small">Мінімальний поріг входу</span><br/>
                        <span class="fw-medium">
                            @if (Model.Post.MinInvestValues?.Any() == true)
                            {
                                @foreach (var c in Model.Post.MinInvestValues)
                                {
                                    <span class="me-2">@c.MinValue&nbsp;@c.Currency</span>
                                }
                            }
                            else
                            {
                                <span>Н/Д</span>
                            }
                        </span>
                    </div>
                </div>

                <!-- Image -->
                @await Html.PartialAsync("Get/PostImage", Model.Post.Post.Image)

                <!-- Date -->
                <p class="text-muted small mb-4">@Model.Post.Post.CreatedAt.ToString("dd-MM-yyyy")</p>

                <!-- Description -->
                <article>
                    @Html.Raw(Model.Post.Post.Description)
                </article>
            </div>

            <!-- Comments -->
            <section class="mt-5">
                @await Html.PartialAsync(
                    "_DisplayComments",
                    (Model.Post.Post.Id, Model.Post.Post.PostType, Model.Post.Post.Comments))
            </section>
        </div>

        <!-- ======== SIDEBAR ======== -->
        <aside class="col-lg-4 pt-lg-2">
            @await Html.PartialAsync(
                "Get/PostSimilarSection",
                (new GetCustomizationSimilarContent {
                    Title = "Схожі оголошення",
                    BaseUrlPrefix = "Invest",
                    MoreContentTitle = "Більше оголошень"
                }, Model.Post.Post.SimilarInvests, Model.Post.Post.Tags))

            <hr class="my-4" />

            @await Html.PartialAsync(
                "Get/PostSimilarSection",
                (new GetCustomizationSimilarContent {
                    Title = "Схожі новини",
                    BaseUrlPrefix = "News",
                    MoreContentTitle = "Більше новин..."
                }, Model.Post.Post.SimilarNews, Model.Post.Post.Tags))
        </aside>
    </div>
</div>