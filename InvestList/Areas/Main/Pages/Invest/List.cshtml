@page "/invest"
@using InvestList
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model InvestList.Areas.Main.Pages.Invest.List

<div class="container">
    @if (Model.Entities != null && Model.Entities.Any())
    {
        <div class="row">
            @foreach (var ad in Model.Entities)
            {
                <div class="col-md-6">
                    <div class="card custom-light-green">
                        <div class="card-body">
                            <h4 class="card-title mb-3">
                                <a class="card-link" asp-area="Main" asp-page="/Invest/Get" asp-route-id="@ad.Id">@ad.Title</a>
                            </h4>
                            <div class="row">
                                <div class="col-auto">
                                    <img src="data:image;base64,@ad.ImageBase64" alt="Placeholder" class="img-fluid rounded" style="width: 100px; height: 100px;">
                                    <div>
                                        <i class="bi bi-percent"></i> @ad.AnnualInvestmentReturn.ToString("0.")
                                    </div>
                                    <div>
                                        <i class="bi bi-calendar-range"></i> @InvestmentHelper.FormatInvestmentDuration(ad.InvestDurationYears, ad.InvestDurationMonths)
                                    </div>
                                    @if (ad.MinInvestValues != null && ad.MinInvestValues.Any())
                                    {
                                        @foreach (var currency in ad.MinInvestValues)
                                        {
                                            <div>
                                                <i class="bi bi-check-circle"></i> @currency.MinValue @currency.Currency
                                            </div>
                                        }
                                    }
                                    <div class="text-muted">
                                        <i class="bi bi-clock-history"></i> @ad.CreatedAt.ToString("dd.MM.yyyy")
                                    </div>

                                </div>
                                <div class="col">
                                    <p class="card-text text-black mb-0">@ad.Description?.Substring(0, Math.Min(ad.Description.Length, 300))</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p>Немає оголошень</p>
    }

</div>
 @if (Model.Entities != null && Model.Entities.Any())
 {
     @await Html.PartialAsync("_Pagination", (Model.PaginationInfo, Model.TagIds))
 }