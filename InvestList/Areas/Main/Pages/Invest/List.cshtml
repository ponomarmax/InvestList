@page "/invest"
@model InvestList.Areas.Main.Pages.Invest.List

<div class="container py-4">

    @if (Model.Entities?.Any() == true)
    {
        <!-- Masonry column layout -->
        <div class="masonry">
            @foreach (var ad in Model.Entities)
            {
                <div class="masonry-item">
                    @await Html.PartialAsync("_InvestCard", ad)
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted fs-5 text-center my-5">Немає оголошень</p>
    }

    @if (Model.Entities?.Any() == true)
    {
        <div class="d-flex justify-content-center mt-5">
            @await Html.PartialAsync("_Pagination", ("Invest", Model.PaginationInfo, Model.TagIds))
        </div>
    }
</div>