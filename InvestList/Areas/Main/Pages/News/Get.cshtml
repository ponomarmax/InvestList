@page "/news/{id}"
@using Radar.UI.Pages.Shared.Get
@model InvestList.Areas.Main.Pages.News.Get

@{
    /* ------------------------------------------------------------------
       TODO: Replace this stub with your real subscription check
       (e.g., bool IsUserHasSubscription = User.IsInRole("Subscriber");)
       ------------------------------------------------------------------ */
    bool IsUserHasSubscription = false;
}

<!-- PAGE CONTAINER -->
<div class="container py-4">

    <!-- Back / Edit row -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
                <i class="bi bi-arrow-left me-1"></i> Назад
            </button>
            @if (Model.CanUserEdit)
            {
                <a asp-page="./Edit" asp-route-id="@Model.Post.Id" class="btn btn-primary btn-sm">
                    Редагувати
                </a>
            }
        </div>
        <a asp-page="./List" class="btn btn-secondary btn-sm">Усі новини</a>
    </div>

    <div class="row gx-lg-3 gy-5">
        <!-- ============ MAIN COLUMN ============ -->
        <div class="col-lg-8 position-relative">   <!-- position-relative for overlay -->

            <!-- Unified 75ch wrapper for title, tags, hero, and body -->
            <div style="max-width:75ch;">

                <!-- Title -->
                <h1 class="display-6 fw-semibold mb-2 text-break">@Model.Post.Title</h1>

                <!-- Tags -->
                @await Html.PartialAsync("Get/PostTags", Model.Post.Tags)

                <!-- Hero image -->
                @await Html.PartialAsync("Get/PostImage", Model.Post.Image)

                <!-- Body (shown only for subscribers) -->
                @if (IsUserHasSubscription)
                {
                    <article style="font-size:1.05rem;line-height:1.7;">
                        @Html.Raw(Model.Post.Description)
                    </article>
                }
                else
                {
                    <!-- Optionally show a short preview here -->
                }
            </div>

            <!-- Blur overlay for non-subscribers -->
            @if (!IsUserHasSubscription)
            {
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 backdrop-blur"
                     style="z-index:5;"></div>
            }
        </div>

        <!-- ============ SIDEBAR ============ -->
        <aside class="col-lg-4 pt-lg-2">
            @await Html.PartialAsync(
                "Get/PostSimilarSection",
                (new GetCustomizationSimilarContent {
                    Title            = "Схожі статті",
                    BaseUrlPrefix    = "News",
                    MoreContentTitle = "Більше статей..."
                }, Model.Post.SimilarNews, Model.Post.Tags))

            <hr class="my-4" />

            @await Html.PartialAsync(
                "Get/PostSimilarSection",
                (new GetCustomizationSimilarContent {
                    Title            = "Схожі оголошення",
                    BaseUrlPrefix    = "Invest",
                    MoreContentTitle = "Більше оголошень..."
                }, Model.Post.SimilarInvests, Model.Post.Tags))
        </aside>
    </div>

    <!-- Sources / links -->
    <section class="mt-5">
        @await Html.PartialAsync("Get/PostLinks", Model.Post.Links)
    </section>

    <!-- Comments -->
    <section class="mt-5">
        @await Html.PartialAsync("_DisplayComments",
            (Model.Post.Id, Model.Post.PostType, Model.Post.Comments))
    </section>
</div>

@if (!IsUserHasSubscription)
{
    <!-- =========================== PAYWALL MODAL =========================== -->
    <div class="modal fade" id="subscribeModal" tabindex="-1"
         aria-labelledby="subscribeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 shadow">
                <div class="modal-header border-0">
                    <h5 id="subscribeModalLabel" class="modal-title fw-semibold">
                        Доступ лише за підпискою
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3">
                        Щоб прочитати повну статтю, оформіть підписку. Ви отримаєте:
                    </p>
                    <ul class="list-unstyled small mb-4">
                        <li><i class="bi bi-check-circle text-success me-1"></i> Необмежений доступ до статей</li>
                        <li><i class="bi bi-check-circle text-success me-1"></i> Коментарі без обмежень</li>
                        <li><i class="bi bi-check-circle text-success me-1"></i> Відсутність реклами</li>
                    </ul>
                    <a asp-area="Main" asp-page="/Subscription/Plan"
                       class="btn btn-primary w-100 rounded-pill py-2">
                        Оформити підписку
                    </a>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            // Show the pay-wall modal automatically
            document.addEventListener('DOMContentLoaded', () => {
                const modal = new bootstrap.Modal(
                    document.getElementById('subscribeModal'),
                    { backdrop: 'static', keyboard: false });
                modal.show();
            });
        </script>
    }

    @section Styles {
        <style>
            /* Quick utility for blur effect without external CSS file */
            .backdrop-blur { backdrop-filter: blur(5px); }
        </style>
    }
}