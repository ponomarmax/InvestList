@page "/news"
@using InvestList
@using InvestList.Services
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Radar.UI
@using Radar.UI.Pages
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Http
@using System.Globalization
@using Core.Interfaces
@model InvestList.Areas.Main.Pages.News.List
@inject IHttpContextAccessor HttpContextAccessor
@inject ITagRepository tagService

<!-- NEWS SECTION TITLE -->
<section class="py-4 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 fw-bold mb-0">Останні новини</h1>
                <p class="text-muted">Актуальні новини про інвестиції та бізнес</p>
            </div>
            <div class="col-md-6">
                <form class="search-form mt-3 mt-md-0" method="get" asp-area="Main" asp-page="/News/List">
                    <div class="input-group">
                        <input type="text" class="form-control rounded-pill" placeholder="Пошук новин..." name="search" value="@Model.Search">
                        <button type="submit" class="search-button">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- NEWS CARDS -->
<section class="py-5">
    <div class="container">
        @if (Model.Entities != null && Model.Entities.Any())
        {
            <div class="row g-4">
                @foreach (var news in Model.Entities)
                {
                    <div class="col-lg-4">
                        @await Html.PartialAsync("List/_PostCard", ("News", news))
                    </div>
                }

                <!-- Google AdSense -->
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm bg-light">
                        <div class="card-body d-flex justify-content-center align-items-center">
                            <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7409000941565147"
                                    crossorigin="anonymous"></script>
                            <ins class="adsbygoogle"
                                 style="display:block"
                                 data-ad-format="fluid"
                                 data-ad-layout-key="-er-s-6z-ez+1nt"
                                 data-ad-client="ca-pub-7409000941565147"
                                 data-ad-slot="8518592844">
                            </ins>
                            <script>
                                (adsbygoogle = window.adsbygoogle || []).push({});
                            </script>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pagination -->
            <div class="mt-5">
                @if (Model.PaginationInfo.TotalPages > 1)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <!-- Previous Button -->
                            <li class="page-item @(Model.PaginationInfo.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link rounded-pill"
                                   asp-area="Main"
                                   asp-page="/News/List"
                                   asp-all-route-data="@(PaginationHelper.GetPaginationData(Model.PaginationInfo.CurrentPage - 1, Model.TagIds, Model.Search))">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            <!-- Page Numbers -->
                            @{
                                var startPage = Math.Max(1, Model.PaginationInfo.CurrentPage - 2);
                                var endPage = Math.Min(Model.PaginationInfo.TotalPages, startPage + 4);

                                if (startPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link rounded-pill" asp-area="Main" asp-page="/News/List"
                                           asp-all-route-data="@(PaginationHelper.GetPaginationData(1, Model.TagIds, Model.Search))">
                                            1
                                        </a>
                                    </li>
                                    if (startPage > 2)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link border-0">...</span>
                                        </li>
                                    }
                                }

                                for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(Model.PaginationInfo.CurrentPage == i ? "active" : "")">
                                        <a class="page-link rounded-pill" asp-area="Main" asp-page="/News/List"
                                           asp-all-route-data="@(PaginationHelper.GetPaginationData(i, Model.TagIds, Model.Search))">
                                            @i
                                        </a>
                                    </li>
                                }

                                if (endPage < Model.PaginationInfo.TotalPages)
                                {
                                    if (endPage < Model.PaginationInfo.TotalPages - 1)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link border-0">...</span>
                                        </li>
                                    }

                                    <li class="page-item">
                                        <a class="page-link rounded-pill" asp-area="Main" asp-page="/News/List"
                                           asp-all-route-data="@(PaginationHelper.GetPaginationData(Model.PaginationInfo.TotalPages, Model.TagIds, Model.Search))">
                                            @Model.PaginationInfo.TotalPages
                                        </a>
                                    </li>
                                }
                            }

                            <!-- Next Button -->
                            <li class="page-item @(Model.PaginationInfo.CurrentPage == Model.PaginationInfo.TotalPages ? "disabled" : "")">
                                <a class="page-link rounded-pill"
                                   asp-area="Main"
                                   asp-page="/News/List"
                                   asp-all-route-data="@(PaginationHelper.GetPaginationData(Model.PaginationInfo.CurrentPage + 1, Model.TagIds, Model.Search))">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="mb-4">
                    <i class="bi bi-newspaper display-1 text-muted"></i>
                </div>
                <h3>Новин не знайдено</h3>
                <p class="text-muted">Спробуйте змінити критерії пошуку або перевірте пізніше.</p>
                <a asp-area="Main" asp-page="/News/List" class="btn btn-outline-dark rounded-pill px-4 mt-3">Всі новини</a>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        // Language switcher functionality
        function switchLanguage(url) {
            window.location.href = url;
        }
    </script>
}