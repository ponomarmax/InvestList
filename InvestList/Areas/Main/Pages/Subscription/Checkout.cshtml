@page "/subscription/checkout"
@model InvestList.Areas.Main.Pages.Subscription.Checkout
@{
    ViewData["Title"] = "Оформити підписку";
}

<!-- PAGE CONTAINER -->
<div class="container py-5">

    <!-- ⚠️  TEMPORARY PAYMENT NOTICE -->
    <div class="alert alert-warning border-0 shadow-sm rounded-4 p-4 mb-5">
        <div class="d-lg-flex align-items-center">
            <div class="flex-grow-1">
                <h2 class="h5 fw-semibold mb-2">
                    Платіжна система тимчасово недоступна
                </h2>
                <p class="mb-0 small text-muted">
                    Ми вже працюємо над вирішенням питання. Щоб ви могли одразу читати
                    <strong>преміум&nbsp;статті та гіди</strong>, даруємо вам <strong>1&nbsp;тиждень безоплатного доступу</strong>.
                </p>
            </div>

            <!-- “Go Premium” button -->
            <a id="goPremiumBtn"
               asp-area="Main" asp-page="/Subscription/List"
               class="btn btn-primary rounded-pill px-4 py-2 mt-3 mt-lg-0 ms-lg-4">
                <i class="bi bi-star-fill me-1"></i> Go&nbsp;Premium
            </a>
        </div>
    </div>

    

</div>

@section Styles {
    <style>
        /* keeps the small ribbon, in case you re-enable plans later */
        .card .badge {
            padding:.5rem .75rem;
            font-size:.75rem;
            transform:translate(-50%,-50%) rotate(10deg);
        }
    </style>
}

@section Scripts {
    <!-- Stripe / WayForPay JS can go here later -->
}