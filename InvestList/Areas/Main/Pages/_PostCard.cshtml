@model InvestList.Models.V2.PostView

<div class="card">
    <div class="card-body">
        <h4 class="card-title mb-3">
            <a class="card-link" asp-area="Main" asp-page="/News/Get" asp-route-id="@Model.Slug">@Model.Title</a>
        </h4>

        @if (Model.Tags != null && Model.Tags.Any())
        {
            <div class="tags-container">
                @foreach (var field in Model.Tags)
                {
                    <span class="tag_index">@field.Name</span>
                }
            </div>
        }
        <hr>

        <div class="row">
            @if (Model.Image != null)
            {
                <div class="col-auto">
                    <img src="@Model.Image.FilePath" alt="@Model.Image.AltText" class="img-fluid rounded" style="width: 100px; height: 100px;">
                </div>
            }

            <div class="col">
                <p class="card-text text-black mb-0">@Model.Description?.Substring(0, Math.Min(Model.Description.Length, 150))</p>
                <div class="creation-data">@Model.CreatedAt.ToString("dd.MM.yyyy")</div>
            </div>
        </div>
    </div>
</div>