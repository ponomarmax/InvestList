@using System.Globalization
@using Core.Interfaces
@using InvestList
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using Radar.UI
@using Radar.UI.Pages
@inject ITagRepository tagService
@inject IWebHostEnvironment env
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="uk">

<head>
    @if (env.IsProduction())
    {
        <!-- Google Tag Manager -->
        <script>(function (w, d, s, l, i) {
                w[l] = w[l] || []; w[l].push({
                    'gtm.start':
                        new Date().getTime(), event: 'gtm.js'
                }); var f = d.getElementsByTagName(s)[0],
                    j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
                        'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
            })(window, document, 'script', 'dataLayer', 'GTM-TDCJJF5S');</script>
        <!-- End Google Tag Manager -->
    }
    <meta charset="utf-8"/>
    <meta name="google-adsense-account" content="ca-pub-7409000941565147">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/svg+xml" href="/ico/logo3.png">
    <title>@(Context.Items["CustomTitle"] ?? ViewData["CustomTitle"] ?? ViewData["Title"])</title>
    @if (Context.Items["CustomDescription"] != null)
    {
        <meta name="description" content="@Context.Items["CustomDescription"]">
    }
    else if (!string.IsNullOrEmpty(ViewData["CustomDescription"] as string))
    {
        <meta name="description" content="@ViewData["CustomDescription"]">
    }
    @{
        var ignoredParams = new[] { "tagIds", "pageIndex" };
        var hasIgnoredParams = Context.Request.Query.Keys.Any(key => ignoredParams.Contains(key));
    }

    @if (hasIgnoredParams)
    {
        <meta name="robots" content="noindex,follow">
    }

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    @await RenderSectionAsync("Styles", required: false)
</head>

<!-- HEADER -->
<header class="border-bottom border-gray-200 py-3 sticky-top bg-white shadow-sm">
    <div class="container">
        <nav class="navbar navbar-expand-lg p-0">
            <a class="navbar-brand me-auto me-lg-4" asp-area="Main" asp-page="/Index">
                <img src="/ico/logo3.png" alt="Invest Radar" height="32">
            </a>

            <button class="navbar-toggler rounded-square" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <!-- Main Navigation -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link px-lg-3" asp-area="Main" asp-page="/News/List">Новини</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-lg-3" asp-area="Main" asp-page="/Invest/List">Проекти</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-lg-3" asp-area="Main" asp-page="/Blacklist/List">Blacklist</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link px-lg-3" asp-area="Main" asp-page="/Subscription/List">Преміум-контент</a>
                    </li>
                </ul>

                <!-- Right Side Elements -->
                <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-3 mt-3 mt-lg-0">
                    <form class="d-flex order-lg-1" role="search" method="get" asp-area="Main" asp-page="/Index">
                        <input class="form-control form-control-sm border rounded-square px-3"
                               type="search"
                               placeholder="Пошук проектів..."
                               name="search"
                               style="width: 100%; max-width: 200px;">
                    </form>

                    @{
                        var rqf = HttpContextAccessor.HttpContext?.Features.Get<IRequestCultureFeature>();
                        var currentCulture = rqf?.RequestCulture.Culture.TwoLetterISOLanguageName ?? "uk";
                        var returnUrl = HttpContextAccessor.HttpContext?.Request.Path + HttpContextAccessor.HttpContext?.Request.QueryString;
                    }
                    <div class="d-flex align-items-center me-lg-3">
                        <a href="@Url.Action("SetLanguage", "Language", new { culture = "uk", returnUrl = returnUrl })"
                           class="lang-pill @(currentCulture == "uk" ? "active" : null)">
                            UA
                        </a>

                        <a href="@Url.Action("SetLanguage", "Language", new { culture = "en", returnUrl = returnUrl })"
                           class="lang-pill @(currentCulture == "en" ? "active" : null)">
                            EN
                        </a>
                    </div>

                    @if (!User.Identity.IsAuthenticated)
                    {
                        <div class="d-flex gap-2 order-lg-3">
                            <a href="/Identity/Account/Login" class="btn btn-outline-dark btn-sm rounded-square px-3">Увійти</a>
                            <a href="/Identity/Account/Login" class="btn btn-dark btn-sm rounded-square px-3">Зареєструватися</a>
                        </div>
                    }
                    else if (User.Identity.IsAuthenticated)
                    {
                        <div class="d-flex gap-2 order-lg-3">
                            <a asp-area="Identity"
                               asp-page="/Account/Profile" class="btn btn-outline-dark btn-sm rounded-square px-3">
                                @User.Identity?.Name
                            </a>
                            <a asp-area="Identity" asp-page="/Account/Logout"
                               asp-route-returnUrl="@Url.Action("Index", new { area = "Main" })" class="btn btn-dark btn-sm rounded-square px-3">
                                Вийти
                            </a>
                        </div>
                        @if (User.IsInRole(Const.AdminRole))

                        {
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   id="adminMenu"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Адмін
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end text-small" aria-labelledby="adminMenu">
                                    <li>
                                        <a class="dropdown-item" asp-area="Main" asp-page="/News/Create">Створити новину</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Main" asp-page="/Blacklist/Create">Створити Blacklist</a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Main" asp-page="/Admin/Index">Додати тег</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Main" asp-page="/Admin/AllSeo">SEO</a>
                                    </li>
                                </ul>
                            </div>
                        }
                    }
                </div>
            </div>
        </nav>
    </div>
</header>

<body>
@RenderBody()

<script src="~/js/site.js" asp-append-version="true"></script>

<footer class="py-5 bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <a href="/" class="d-inline-block mb-4">
                    <img src="/ico/logo3.png" alt="Invest Radar" height="32">
                </a>
                <p class="text-muted mb-0">Платформа для пошуку інвестиційних можливостей та залучення інвестицій в Україні.</p>
                <div class="d-flex gap-3 mt-4">
                    <a href="#" class="text-dark">
                        <i class="bi bi-facebook"></i>
                    </a>
                    <a href="#" class="text-dark">
                        <i class="bi bi-twitter"></i>
                    </a>
                    <a href="#" class="text-dark">
                        <i class="bi bi-linkedin"></i>
                    </a>
                    <a href="#" class="text-dark">
                        <i class="bi bi-instagram"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-2">
                <h5 class="h6 mb-3">Категорії</h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Огляди</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Фін бізнес</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Агро</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Будівництво</a>
                    </li>
                </ul>
            </div>
            <div class="col-lg-3">
                <h5 class="h6 mb-3">Для інвесторів</h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Знайти проект</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Перед інвестуванням</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Фондовий ринок</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">УкрінвестКлуб</a>
                    </li>
                </ul>
            </div>
            <div class="col-lg-3">
                <h5 class="h6 mb-3">Для бізнесу</h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Додати проект</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Залучити інвестиції</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Консультації</a>
                    </li>
                    <li class="mb-2">
                        <a href="#" class="text-muted text-decoration-none">Партнерська програма</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</footer>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
@await RenderSectionAsync("Scripts", required: false)
<link rel="stylesheet" href="https://uicdn.toast.com/editor/latest/toastui-editor.min.css"/>
<script src="https://uicdn.toast.com/editor/latest/toastui-editor-all.min.js"></script>
<script src="~/radar-ui/js/description-text.js"></script>
<script src="~/radar-ui/js/site.js"></script>
<script src="~/radar-ui/js/handleImageUpload.js"></script>
<script src="~/radar-ui/js/add-links.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</body>

</html>