@model (PaginationInfo PaginationInfo, FilterRequestModel FilterModel)
@if (Model.PaginationInfo.TotalPages > 1)
{
    <div class="container mt-3">
        <nav>
            <ul class="pagination justify-content-center">
                <!-- Previous Button -->
                 @if (Model.PaginationInfo.CurrentPage > 1)
                {
                    <li class="page-item @(Model.PaginationInfo.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@GetPageUrl(Model.PaginationInfo.CurrentPage - 1)" tabindex="-1" aria-disabled="@(Model.PaginationInfo.CurrentPage == 1 ? "true" : "false")">Попередня</a>
                    </li>
                }
                <!-- Current Page -->
                <li class="page-item"><span class="page-link">@Model.PaginationInfo.CurrentPage / @Model.PaginationInfo.TotalPages</span></li>

                <!-- Next Button -->
                @if (Model.PaginationInfo.CurrentPage < Model.PaginationInfo.TotalPages)
                {
                    <li class="page-item @(Model.PaginationInfo.CurrentPage == Model.PaginationInfo.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@GetPageUrl(Model.PaginationInfo.CurrentPage + 1)" tabindex="-1" aria-disabled="@(Model.PaginationInfo.CurrentPage == Model.PaginationInfo.TotalPages ? "true" : "false")">Наступна</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
@functions {
    string GetPageUrl(int page)
    {
        var url = Url.Action("Index", new { page });

        if (Model.FilterModel != null)
        {
            url += $"&Currency={Model.FilterModel.Currency}";
            if (Model.FilterModel.MinInvestment != default) url += $"&MinInvestment={Model.FilterModel.MinInvestment}";
            if (Model.FilterModel.MaxInvestment != default) url += $"&MaxInvestment={Model.FilterModel.MaxInvestment}";
            if (Model.FilterModel.MinAnnualInvestmentReturn != default) url += $"&MinAnnualInvestmentReturn={Model.FilterModel.MinAnnualInvestmentReturn}";
            if (Model.FilterModel.MaxAnnualInvestmentReturn != default) url += $"&MaxAnnualInvestmentReturn={Model.FilterModel.MaxAnnualInvestmentReturn}";
        }

        return url;
    }
}
