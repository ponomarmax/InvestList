@using InvestList.Services
@using DataAccess.Repositories
@inject ITagRepository tagService
<!DOCTYPE html>
<html lang="uk">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-L7JXWKK250"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
    
      gtag('config', 'G-L7JXWKK250');
    </script>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/svg+xml" href="/ico/favicon.svg">
    <title>@(ViewData["CustomTitle"] ?? ViewData["Title"])</title>
    @if (!string.IsNullOrEmpty(ViewData["CustomDescription"] as string))
    {
        <meta name="description" content="@ViewData["CustomDescription"]">
    }
    @if (ViewData["DisplayNoIndexTag"] as bool? == true)
    {
        <meta name="robots" content="noindex,follow">
    }
    @* @if (Context.Request.QueryString.HasValue && Context.Request.QueryString.Value.Contains("page")) *@
    @* { *@
    @*     <link rel="canonical" href="@Context.Request.Scheme://@Context.Request.Host@Context.Request.Path"> *@
    @*     *@
    @* } *@

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<header class="d-flex justify-content-center flex-wrap">
    <a class="navbar-brand px-5" asp-area="" asp-controller="Invest" asp-action="Index">
        <img src="/ico/logo1.svg" alt="invest radar logo" height="40" width="40"/>
        <span>Invest Radar для інвесторів та підприємців</span>
    </a>

    <partial name="_LoginPartial"/>
</header>
<div class="my-2">
    <ul class="nav col-12 col-md-auto mb-2 justify-content-center mb-md-0">
        @if (User.IsInRole(Const.AdminRole))
        {
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-current="page">
                    НОВИНИ
                </a>
                <ul class="dropdown-menu">
                    <li>
                        <a asp-area="Main" asp-page="/News/List" class="dropdown-item">Переглянути новини</a>
                    </li>
                    <li>
                        <a asp-area="Main" asp-page="/News/Create" class="dropdown-item">Створити новину</a>
                    </li>
                </ul>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="Main" asp-page="/News/List">Переглянути новини</a>
            </li>
        }
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Інвестиційні пропозиції
            </a>
            <ul class="dropdown-menu">
                <li>
                    <a asp-area="Main" asp-page="/Invest/List" class="dropdown-item">Всі заявки</a>
                </li>
                <li>
                    <a asp-area="Main" asp-page="/Invest/Create" class="dropdown-item">Створити заявку</a>
                </li>
            </ul>
        </li>

        <li class="nav-item">
            <a class="nav-link" href="https://forms.gle/srpVQNdRnvtQBF886"><i class="bi bi-google"></i> Хочу інвестувати</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" href="https://forms.gle/DTgQQGUEixvhyLAA7"><i class="bi bi-google"></i> Жертвам інвестування</a>
        </li>
        @if (User.IsInRole(Const.AdminRole))
        {
            <li class="nav-item">
                <a asp-action="Index" asp-controller="Admin" class="nav-link">Додати тег</a>
            </li>
        }
    </ul>
</div>

@{
    var header = await tagService.GetCustomHeader();
    if (header?.Count() > 0)
    {
        <div class="my-2">
            <ul class="nav col-12 col-md-auto mb-2 justify-content-center mb-md-0">
                @foreach (var tag in header)
                {
                    <li class="nav-item">
                        <a class="nav-link"
                                       asp-area="Main"
                                       asp-page="/News/List"
                                       asp-all-route-data="@(InvestmentHelper.GetPaginationData(tagIds: new[] { tag.TagId }))">
                                        #@tag.Tag.Name
                                    </a>
                    </li>
                }
            </ul>
        </div>
    }
}

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top bg-light text-dark py-3">
    <ul class="nav justify-content-center border-bottom pb-3 mb-3">
        <li class="nav-item">
            <a href="https://t.me/invesstradar" class="nav-link px-2 creation-data"><i class="bi-telegram"></i> Telegram</a>
        </li>
        <li class="nav-item">
            <a href="https://forms.gle/DTgQQGUEixvhyLAA7" class="nav-link px-2 creation-data"><i class="bi bi-google"></i> Ваш досвід інвестування</a>
        </li>
        <li class="nav-item">
            <a href="https://forms.gle/BpSkLHWuq6y7yRiP9" class="nav-link px-2 creation-data"><i class="bi bi-google"></i> Фідбек по роботі сайту</a>
        </li>
        <li class="nav-item">
            <a href="/privacy-policy.html" class="nav-link px-2 creation-data">Політика конфіденційності</a>
        </li>
    </ul>
</footer>
@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
@await RenderSectionAsync("Scripts", required: false)
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>