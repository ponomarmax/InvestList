@{
    var header = await tagService.GetCustomHeader();
    if (header?.Count() > 0)
    {
        <div class="nav-panel my-2">
            <ul class="nav nav-tags col-12 col-md-auto mb-2 mb-md-0">
                @foreach (var tag in header)
                {
                    <li class="nav-item">
                        <a class="nav-link"
                            asp-area="Main"
                            asp-page="/Index"
                            asp-all-route-data="@(InvestmentHelper.GetPaginationData(tagIds: new[] { tag.TagId }))">
                            @tag.Tag.Name
                        </a>
                    </li>
                }
            </ul>
        </div>
    }
}

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
