@model IEnumerable<WebApplication1.Models.GetAllAdsView>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
    <h1>Index</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </p>

<div class="container">

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img src="https://via.placeholder.com/800" class="card-img-top" alt="Post Image">
                    <div class="card-body">
                        <h5 class="card-title">@item.Title</h5>

                        <p class="card-text">Автор: <a href="#">@item.Author</a><br></p>
                        <p class="card-text">@FormatTimeSpanAsYearsAndMonths(item.InvestPeriod)</p>
                        <!-- Add other details as needed -->
                        
                        <p class="card-text">Створено: @item.CreatedAt.ToString("dd.MM.yyyy")</p>
                        
                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-primary">Детальніше</a>
                        <a href="#">Коментарів <span class="badge">10</span></a><br>
                        <a href="#">Оновлень <span class="badge">2</span></a>
                    </div>  
                </div>
            </div>
        }
    </div>
</div>

@functions {
    public string FormatTimeSpanAsYearsAndMonths(TimeSpan duration)
    {
        var totalMonths = (int)duration.TotalDays / 30;
        var years = totalMonths / 12;
        var months = totalMonths % 12;
        if (years>0)
        return $"{years} років і {months} місяців";
        return $"{months} місяців";
    }
}
