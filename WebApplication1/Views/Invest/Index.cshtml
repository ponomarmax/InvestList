@model IEnumerable<WebApplication1.Models.GetAllAdsView>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
    <h1>Index</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </p>

<div class="container">

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img class="card-img-top" src="https://via.placeholder.com/300" alt="Card image cap">
                    <div class="card-body">
                        <div class="tag tag1">Автобізнес</div>
                        <div class="tag tag2">Агробізнес</div>
                        <div class="tag tag3">Нерухомість</div>
                        <h5 class="card-title">@item.Title</h5>
                        <p><small class="text-muted">@item.CreatedAt.ToString("dd.MM.yyyy")</small></p>
                        <p class="card-text">
                            <small class="text-muted">
                                <img src="https://via.placeholder.com/24" alt="Author Avatar" class="avatar">
                                Author: Author Name
                                <p class="card-text">Автор: <a href="#">@item.Author</a><br></p>
                            </small>
                        </p>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's
                            content.</p>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item"><i class="fas fa-percent"></i> Feature 1</li>
                                <li class="list-group-item"><i class="fas fa-money-bill"></i> Feature 2</li>
                                <li class="list-group-item"><i class="fas fa-coins"></i> Feature 3</li>
                                <li class="list-group-item"><i class="fas fa-coins"></i>@FormatTimeSpanAsYearsAndMonths(item.InvestPeriod)</li>
                            </ul>
                        <div class="views-comments">
                            <p><small class="text-muted"><i class="fas fa-eye"></i> 100</small></p>
                            <p><small class="text-muted"><i class="fas fa-comment"></i> 20</small></p>
                        </div>
                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn btn-primary">Детальніше</a>
                        <a href="#" class="card-link">GitHub</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@functions {
    public string FormatTimeSpanAsYearsAndMonths(TimeSpan duration)
    {
        var totalMonths = (int)duration.TotalDays / 30;
        var years = totalMonths / 12;
        var months = totalMonths % 12;
        if (years>0)
        return $"{years} років і {months} місяців";
        return $"{months} місяців";
    }
}
