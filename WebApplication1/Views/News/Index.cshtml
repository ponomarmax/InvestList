@model ListNewsViewModel

@{
    ViewData["Title"] = "Новини";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    @if (Model.Entities != null && Model.Entities.Any())
    {
        <div class="row">
            @foreach (var ad in Model.Entities)
            {
                <div class="col-6 col-lg-3 mb-3">
                    <a class="card-link" href="@Url.Action("Details", new { id = ad.Id })">
                        <div class="card">
                            <div class="card-header">
                                <div class="card-title">@ad.Title</div>
                            </div>
                            <div class="card-body">
                                <div class="tags mb-3">
                                    <span class="badge bg-primary">Технології</span>
                                    <span class="badge bg-primary">Інвестиції</span>
                                    <span class="badge bg-primary">Інновації</span>
                                </div>
                                <div> <i class="bi bi-percent"></i>Автор: <a href="#">@ad.Author</a></div>
                                <div><i class="bi bi-calendar-range"></i>@ad.CreatedAt.ToString("dd.MM.yyyy")</div>

                                @if (ad?.Tags?.Any() == true)
                                {
                                    <p class="card-text mb-4">
                                        Галузі інвестування:
                                        @foreach (var field in ad.Tags)
                                        {
                                            <span class="badge bg-primary">@field.Name</span>
                                        }
                                    </p>
                                }
                            </div>
                        </div>
                    </a>
                </div>

            }
        </div>
    }
    else
    {
        <p>Немає новин</p>
    }

</div>


