@using DataAccess.Models;
@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a  class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Вітаюємо Вас, @User.Identity?.Name!</a>
    </li>
    <li class="nav-item">
        <form  class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Invest", new { area = "" })">
            <button  type="submit" class="nav-link btn btn-link text-dark">Вийти</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Register" asp-action="Index">Зареєструватися</a>
    </li>
    <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Login" asp-action="Index">Війти</a>
    </li>
}
</ul>
