@using DataAccess.Models;
@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        Мій кабінет
    </a>
    <ul class="dropdown-menu">
        @if (SignInManager.IsSignedIn(User))
        {
            <li class="nav-item">
                <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage"> @User.Identity?.Name!</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Invest", new { area = "" })"> Вийти</a>
            </li>
        }
        else
        {

            <div class="col-md-3 text-end">
                <button type="button" class="btn btn-primary" asp-controller="Register" asp-action="Index"> Зареєструватися</button>
            
            
                <button type="button" class="btn btn-outline-primary me-2" asp-controller="Login" asp-action="Index"> Війти</button>
            </div>
        }
    </ul>
</li>


